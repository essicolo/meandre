# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
.venv-wsl/
.pytest_cache/

# --- Logs ---
fdc_training.log
training_*.log

# --- Editor / OS ---
.vscode/
.claude/
gitignore_bak

# --- Binary artefacts (apply everywhere) ---
# Model checkpoints
*.pt
*.pth
# Databases
*.duckdb
*.duckdb.wal
*.sqlite3
# Scientific data formats
*.nc
*.nc.bak*
*.tif
*.npy
*.pkl
# Tabular outputs (run results); small inputs in data/ are opted-in below
*.parquet
# Plot outputs
*.png
*.jpg
*.jpeg
# GeoSpatial proprietary
*.gpkg
*.qgz
.gpkg/
# Shapefile cluster (rare to want tracked)
*.shp
*.shx
*.dbf
*.prj
*.sbn
*.sbx
*.cpg

# --- HYDAT specific ---
Hydat_sqlite3_*.zip

# --- Runs workspaces ---
# Local artefacts ignored, code + configs tracked.
# Pattern: (a) ignore everything under .runs/ recursively, (b) re-include
# directories so git can descend, (c) re-include .py and .toml at any depth.
/.runs/**/*
!/.runs/**/
!/.runs/**/*.py
!/.runs/**/*.toml
!/.runs/**/README*

# --- Shared data inputs ---
# data/ contains large parquet/shapefile inputs. Specific files re-included below.
/data/**/*
!/data/**/
!/data/station_info.csv

# --- Other modeling applications (workspace local, hors git) ---
# Conventions : dot-préfixe = workspace local, non partagé via git.
.papers/
.reports/
