<mxfile host="Electron" agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/28.2.5 Chrome/138.0.7204.251 Electron/37.6.1 Safari/537.36" version="28.2.5">
  <diagram name="HydroModel Architecture" id="model-arch">
    <mxGraphModel dx="4844" dy="3473" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="3300" pageHeight="2400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;model — Differentiable Hydrological Model&lt;/b&gt;&lt;br&gt;&lt;i&gt;Physics-based vertical column + neural routing&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="315" y="-580" width="600" height="50" as="geometry" />
        </mxCell>
        <mxCell id="grp_inputs" value="inputs (T: time, N: nodes)" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="50" y="-320" width="1130" height="220" as="geometry" />
        </mxCell>
        <mxCell id="in_forcing" value="&lt;b&gt;Weather forcing&lt;/b&gt;&lt;br&gt;(T, N, 6)&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Daily P (mm), T_min/T_max (C), net radiation (MJ/m²/day), wind speed (m/s), actual vapor pressure (kPa). From ERA5/RDRS gridded data, interpolated to node centroids.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;" parent="grp_inputs" vertex="1">
          <mxGeometry x="10" y="30" width="130" height="170" as="geometry" />
        </mxCell>
        <mxCell id="in_coords" value="&lt;b&gt;Node Coords&lt;/b&gt;&lt;br&gt;(N, 2) [lon, lat]&lt;br&gt;Longitude/latitude of each reach centroid." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;" parent="grp_inputs" vertex="1">
          <mxGeometry x="150" y="30" width="130" height="170" as="geometry" />
        </mxCell>
        <mxCell id="in_terr" value="&lt;b&gt;Territorial&lt;/b&gt;&lt;br&gt;(N, 17)&lt;br&gt;&lt;font size=&quot;1&quot;&gt;static landscape features&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: x-small; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;per node: land use fractions, soil type, slope, drainage area, etc. Imported From Physitel.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;" parent="grp_inputs" vertex="1">
          <mxGeometry x="290" y="30" width="130" height="170" as="geometry" />
        </mxCell>
        <mxCell id="in_graph" value="&lt;b&gt;RiverGraph&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;edges, topo_order,&lt;br&gt;is_lake&lt;br&gt;Network topology: edge_index (upstream→downstream), topo_order, is_lake flags, edge attributes (length, slope).&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;" parent="grp_inputs" vertex="1">
          <mxGeometry x="430" y="30" width="130" height="170" as="geometry" />
        </mxCell>
        <mxCell id="in_state" value="&lt;b&gt;Initial State&lt;/b&gt;&lt;br&gt;HydroState (N, 9)&lt;br&gt;&lt;font size=&quot;1&quot;&gt;theta1/2/3, swe, t_soil,&lt;br&gt;canopy, wetland, S_gw, T_water&lt;br&gt;Starting values for soil moisture (3 layers), SWE, soil temperature, canopy storage, wetland storage. Usually zeros (model spins up).&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;" parent="grp_inputs" vertex="1">
          <mxGeometry x="570" y="30" width="140" height="170" as="geometry" />
        </mxCell>
        <mxCell id="in_withdraw" value="&lt;b&gt;Withdrawals&lt;/b&gt;&lt;br&gt;(T, N) × 5 types&lt;br&gt;&lt;font size=&quot;1&quot;&gt;GPE, PR, ELEVAGE,&lt;br&gt;EFFLUENT, CULTURE&lt;br&gt;Water removed/added per reach per day in m³/s.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;" parent="grp_inputs" vertex="1">
          <mxGeometry x="720" y="30" width="140" height="170" as="geometry" />
        </mxCell>
        <mxCell id="in_doy" value="&lt;b&gt;Day of Year&lt;/b&gt;&lt;br&gt;(T,) 1-366&lt;br&gt;Integer 1-366 for sinusoidal seasonal encoding.&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;" parent="grp_inputs" vertex="1">
          <mxGeometry x="870" y="30" width="110" height="170" as="geometry" />
        </mxCell>
        <mxCell id="in_qobs" value="&lt;b&gt;Q_obs&lt;/b&gt;&lt;br&gt;(T, n_stations)&lt;br&gt;&lt;font size=&quot;1&quot;&gt;observed discharge&lt;br&gt;NaN = missing&lt;br&gt;Observed discharge at gauge stations, NaN for missing. Not used by the model forward pass — only by the loss function.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;" parent="grp_inputs" vertex="1">
          <mxGeometry x="990" y="30" width="130" height="170" as="geometry" />
        </mxCell>
        <mxCell id="grp_spatial" value="SpatialFieldNetwork" style="swimlane;startSize=35;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="50" y="-40" width="300" height="530" as="geometry" />
        </mxCell>
        <mxCell id="sp_fourier" value="&lt;b&gt;coord_enc&lt;/b&gt;: FourierPositionalEncoding&lt;br&gt;&lt;font size=&quot;1&quot;&gt;(lon, lat) → 6 freq bands × sin/cos + raw = 26D&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="grp_spatial" vertex="1">
          <mxGeometry x="10" y="40" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sp_concat" value="concat([enc, territorial]) → &lt;b&gt;x0&lt;/b&gt; (26+17 = 43D)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" parent="grp_spatial" vertex="1">
          <mxGeometry x="10" y="140" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sp_output" value="&lt;b&gt;SpatialParams (N, 27)&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;K_sat×3, porosity×3, FC×3, WP×3, f_root×3&lt;br&gt;C_f, T_melt, T_snow, intercept_cap, frost_α&lt;br&gt;f_wetland, slope_factor, krec, k_gw, T_gw, K_atm&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=0;" parent="grp_spatial" vertex="1">
          <mxGeometry x="10" y="440" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sp_constraints" value="&lt;b&gt;_apply_constraints()&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;scaled-tanh: center + range × tanh(raw × 0.3)&lt;br&gt;log-normal for K_sat/krec, softmax for f_root&lt;br&gt;chained fractions: porosity → FC → WP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="grp_spatial" vertex="1">
          <mxGeometry x="10" y="340" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sp_mlp" value="&lt;b&gt;fc1&lt;/b&gt;(43→256) → SiLU → cat(h, x0) →&lt;br&gt;&lt;b&gt;fc2&lt;/b&gt;(299→256) → SiLU → &lt;b&gt;fc_out&lt;/b&gt;(256→27)&lt;br&gt;&lt;font size=&quot;1&quot;&gt;skip connection, MC Dropout (self.drop)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="grp_spatial" vertex="1">
          <mxGeometry x="10" y="240" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="spa1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" parent="grp_spatial" source="sp_fourier" target="sp_concat" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="spa2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" parent="grp_spatial" source="sp_concat" target="sp_mlp" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="spa3" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" parent="grp_spatial" source="sp_mlp" target="sp_constraints" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="spa4" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" parent="grp_spatial" source="sp_constraints" target="sp_output" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="grp_tce" value="TemporalContextEncoder" style="swimlane;startSize=35;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="400" y="-40" width="310" height="330" as="geometry" />
        </mxCell>
        <mxCell id="tce_proj" value="&lt;b&gt;input_proj&lt;/b&gt;: Linear(6→64)&lt;br&gt;+ &lt;b&gt;doy_encoding&lt;/b&gt;: SinusoidalDOYEncoding(64)&lt;br&gt;&lt;font size=&quot;1&quot;&gt;element-wise addition (not concat)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="grp_tce" vertex="1">
          <mxGeometry x="10" y="40" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="tce_gru" value="&lt;b&gt;rnn&lt;/b&gt;: GRU(64, 64, num_layers=1)&lt;br&gt;&lt;font size=&quot;1&quot;&gt;chunked TBPTT (chunk_size=90 days)&lt;br&gt;gradient checkpointing for memory&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="grp_tce" vertex="1">
          <mxGeometry x="10" y="140" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="tce_out" value="&lt;b&gt;norm&lt;/b&gt;: LayerNorm(64) → &lt;b&gt;output_proj&lt;/b&gt;: Linear(64→16)&lt;br&gt;→ &lt;b&gt;all_context (T, N, 16)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="grp_tce" vertex="1">
          <mxGeometry x="10" y="240" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="tca1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" parent="grp_tce" source="tce_proj" target="tce_gru" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tca2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" parent="grp_tce" source="tce_gru" target="tce_out" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="grp_temporal" value="TEMPORAL LOOP (for t = 0 to t-1)" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;rounded=1;fontSize=14;fontColor=#333333;" parent="1" vertex="1">
          <mxGeometry x="30" y="530" width="910" height="1120" as="geometry" />
        </mxCell>
        <mxCell id="enrich" value="&lt;b&gt;Enriched Forcing&lt;/b&gt;&lt;br&gt;[forcing[t] | context[t]]&lt;br&gt;(N, 6+16=22)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="grp_temporal" vertex="1">
          <mxGeometry x="660" y="60" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="grp_vertical" value="Vertical Column (7-module physics chain)" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=13;" parent="grp_temporal" vertex="1">
          <mxGeometry x="20" y="50" width="480" height="740" as="geometry" />
        </mxCell>
        <mxCell id="v_snow" value="&lt;b&gt;1. Snow Module&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;P → rain/snow partition (T_snow)&lt;br&gt;Melt = C_f × softplus(T - T_melt)&lt;br&gt;P_eff = P_rain + melt&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b3d9ff;strokeColor=#6c8ebf;" parent="grp_vertical" vertex="1">
          <mxGeometry x="10" y="35" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="v_snow_io" value="SWE →&lt;br&gt;← swe_new" style="text;html=1;fontSize=9;align=left;" parent="grp_vertical" vertex="1">
          <mxGeometry x="305" y="47.5" width="80" height="30" as="geometry" />
        </mxCell>
        <mxCell id="v_snow_out" value="&lt;b&gt;P_eff&lt;/b&gt;" style="text;html=1;fontSize=10;fontStyle=1;align=center;verticalAlign=middle;" parent="grp_vertical" vertex="1">
          <mxGeometry x="104" y="95" width="60" height="15" as="geometry" />
        </mxCell>
        <mxCell id="v_frost" value="&lt;b&gt;2. Frost Module&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;T_soil relaxation toward T_air&lt;br&gt;K_sat_1_eff = K_sat_1 × frost_factor&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b3d9ff;strokeColor=#6c8ebf;" parent="grp_vertical" vertex="1">
          <mxGeometry x="10" y="120" width="280" height="45" as="geometry" />
        </mxCell>
        <mxCell id="v_frost_io" value="t_soil →&lt;br&gt;← t_soil_new" style="text;html=1;fontSize=9;align=left;" parent="grp_vertical" vertex="1">
          <mxGeometry x="305" y="127.5" width="80" height="30" as="geometry" />
        </mxCell>
        <mxCell id="v_intercept" value="&lt;b&gt;3. Interception&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Canopy fill → P_throughfall&lt;br&gt;E_canopy = min(ETP, storage)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b3d9ff;strokeColor=#6c8ebf;" parent="grp_vertical" vertex="1">
          <mxGeometry x="10" y="200" width="280" height="45" as="geometry" />
        </mxCell>
        <mxCell id="v_int_io" value="canopy →&lt;br&gt;← canopy_new" style="text;html=1;fontSize=9;align=left;" parent="grp_vertical" vertex="1">
          <mxGeometry x="305" y="207.5" width="90" height="30" as="geometry" />
        </mxCell>
        <mxCell id="v_et" value="&lt;b&gt;4. Evapotranspiration&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Penman-Monteith ETP (FAO-56)&lt;br&gt;ET_i = ETP × f_root_i × stress(θ_i)&lt;br&gt;stress = (θ - WP)/(FC - WP)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b3d9ff;strokeColor=#6c8ebf;" parent="grp_vertical" vertex="1">
          <mxGeometry x="10" y="280" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="v_et_out" value="&lt;b&gt;ET1, ET2, ET3&lt;/b&gt;" style="text;html=1;fontSize=10;fontStyle=1;align=center;verticalAlign=middle;" parent="grp_vertical" vertex="1">
          <mxGeometry x="60" y="350" width="100" height="15" as="geometry" />
        </mxCell>
        <mxCell id="v_soil" value="&lt;b&gt;5. Soil Module&lt;/b&gt; (3-layer van Genuchten)&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Z1=0.3m, Z2=0.7m, Z3=1.0m&lt;br&gt;• Saturation-excess runoff (layer 1)&lt;br&gt;• Inter-layer Darcy flux: K(θ) × (dψ/dz + 1)&lt;br&gt;• Interflow (layers 1+2): f(excess × slope)&lt;br&gt;• Baseflow (layer 3): K(θ₃) or krec × Z₃ × θ₃&lt;br&gt;• Mass balance: Δθ = (in - out - ET) / z&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b3d9ff;strokeColor=#6c8ebf;" parent="grp_vertical" vertex="1">
          <mxGeometry x="10" y="380" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="v_soil_io" value="θ1/2/3 →&lt;br&gt;← θ1/2/3 new" style="text;html=1;fontSize=9;align=left;" parent="grp_vertical" vertex="1">
          <mxGeometry x="305" y="298" width="80" height="30" as="geometry" />
        </mxCell>
        <mxCell id="v_soil_out" value="&lt;b&gt;R_surface&lt;br&gt;interflow&lt;br&gt;baseflow&lt;/b&gt;" style="text;html=1;fontSize=10;fontStyle=1;align=center;" parent="grp_vertical" vertex="1">
          <mxGeometry x="76" y="477" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="v_wetland" value="&lt;b&gt;6. Wetland Module&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;R_wet = R_surface × f_wetland&lt;br&gt;Q_wet = k × S^β (power-law)&lt;br&gt;R_direct = R_surface × (1 - f_wetland)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b3d9ff;strokeColor=#6c8ebf;" parent="grp_vertical" vertex="1">
          <mxGeometry x="10" y="520" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="v_wet_io" value="wetland →&lt;br&gt;← wetland_new" style="text;html=1;fontSize=9;align=left;" parent="grp_vertical" vertex="1">
          <mxGeometry x="300" y="430" width="90" height="30" as="geometry" />
        </mxCell>
        <mxCell id="FtdpPyqYreaSlpyzp5ir-1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;curved=0;" parent="grp_vertical" source="v_aquifer" target="v_wet_out" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="v_aquifer" value="&lt;b&gt;7. Aquifer Module&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Lumped linear reservoir: dS/dt = recharge - k_gw × S&lt;br&gt;Q_recharge = k_gw × S_gw (analytical solution)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b3d9ff;strokeColor=#6c8ebf;" parent="grp_vertical" vertex="1">
          <mxGeometry x="10" y="600" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="v_aq_io" value="S_gw →&lt;br&gt;← S_gw_new" style="text;html=1;fontSize=9;align=left;" parent="grp_vertical" vertex="1">
          <mxGeometry x="305" y="608" width="80" height="30" as="geometry" />
        </mxCell>
        <mxCell id="va6" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" parent="grp_vertical" source="v_wetland" target="v_aquifer" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="v_wet_out" value="&lt;b&gt;lateral_inflow&lt;/b&gt;&lt;br&gt;(N,) mm/day&lt;br&gt;&lt;font size=&quot;1&quot;&gt;= R_direct + Q_wet&lt;br&gt;+ interflow + Q_baseflow&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=0;" parent="grp_vertical" vertex="1">
          <mxGeometry x="310" y="650" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="va1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" parent="grp_vertical" source="v_snow" target="v_frost" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="va2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" parent="grp_vertical" source="v_frost" target="v_intercept" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="va3" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" parent="grp_vertical" source="v_intercept" target="v_et" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="va4" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" parent="grp_vertical" source="v_et" target="v_soil" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="va5" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" parent="grp_vertical" source="v_soil" target="v_wetland" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="grp_corrections" value="State Corrections" style="swimlane;startSize=25;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=12;" parent="grp_temporal" vertex="1">
          <mxGeometry x="570" y="120" width="320" height="300" as="geometry" />
        </mxCell>
        <mxCell id="residual" value="&lt;b&gt;Residual Corrector&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;GRU over state_history (N, 14, 9)&lt;br&gt;δ = proj(gru_hidden)&lt;br&gt;state_corrected = physics + gate × δ&lt;br&gt;gate init ≈ 0.05 (starts as pure physics)&lt;br&gt;Zero-sum constraint on soil layers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="grp_corrections" vertex="1">
          <mxGeometry x="10" y="40" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="noise" value="&lt;b&gt;AR(1) State Noise&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;η_t = ρ × η_{t-1} + σ × ε_t&lt;br&gt;Applied to θ1, θ2, θ3, SWE&lt;br&gt;Learned ρ (persistence) and σ (amplitude)&lt;br&gt;For ensemble uncertainty&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="grp_corrections" vertex="1">
          <mxGeometry x="10" y="190" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="arr_vc" value="HydroState" style="edgeStyle=orthogonalEdgeStyle;curved=0;strokeWidth=1;strokeColor=#d6b656;fontStyle=2;fontSize=10;rounded=1;fillColor=#fff2cc;" parent="grp_temporal" source="grp_vertical" target="grp_corrections" edge="1">
          <mxGeometry relative="1" as="geometry">
