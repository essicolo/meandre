        <mxCell id="r_topo" value="&lt;b&gt;Topological Sweep&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Kahn&#39;s algorithm levels&lt;br&gt;Per-level: scatter_add(Q_out[src] → Q_agg[dst])&lt;br&gt;Apply net_withdrawal: Q_in = clamp(Q_agg - W_net, 0)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="grp_routing" vertex="1">
          <mxGeometry x="10" y="45" width="270" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r_musk" value="&lt;b&gt;Muskingum-Cunge&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Q_out = (c0+c1)×Q_in + c2×Q_prev + (c0+c1)×q_lat&lt;br&gt;K ≥ 0.5h (softplus), x ∈ (0, 0.5)&lt;br&gt;dt = 86400s, n_substeps = 1&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="grp_routing" vertex="1">
